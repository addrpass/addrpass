{
  "manifest_version": 3,
  "name": "AddrPass — Address Privacy",
  "version": "0.1.0",
  "description": "Stop giving your address to every website. Autofill from your encrypted vault or share a tokenized link instead.",
  "browser_specific_settings": {
    "gecko": {
      "id": "extension@addrpass.com",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["personallyIdentifyingInfo", "authenticationInfo"],
        "optional": []
      }
    },
    "gecko_android": {
      "strict_min_version": "120.0"
    }
  },
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://api.addrpass.com/*",
    "https://addrpass.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "scripts": ["background/background.js"]
  }
}
